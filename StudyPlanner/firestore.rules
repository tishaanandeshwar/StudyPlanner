rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, createdAt
    //
    // Collection: tasks
    // Fields: userId, title, subject, deadline, priority, completed, createdAt
    //
    // Collection: sessions
    // Fields: userId, duration, subject, timestamp
    //
    // Collection: plans
    // Fields: userId, subjects, examDates, studyHoursPerDay, difficulty, planData, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isNewDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }

    // Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'title', 'completed']) &&
             data.userId is string &&
             data.title is string && data.title.size() < 200 &&
             data.completed is bool;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['userId', 'duration', 'timestamp']) &&
             data.userId is string &&
             data.duration is number &&
             data.timestamp is string;
    }

    function isValidPlan(data) {
      return data.keys().hasAll(['userId', 'planData']) &&
             data.userId is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidTask(request.resource.data);
      allow update: if isDocOwner() && isValidTask(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /sessions/{sessionId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidSession(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /plans/{planId} {
      allow read: if isDocOwner();
      allow create: if isNewDocOwner() && isValidPlan(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
