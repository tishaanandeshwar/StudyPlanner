{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "StudyTask": {
      "title": "StudyTask",
      "description": "A study task or deadline",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "completed"]
    },
    "FocusSession": {
      "title": "FocusSession",
      "description": "A logged focus session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "duration": { "type": "number" },
        "subject": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "duration", "timestamp"]
    },
    "StudyPlan": {
      "title": "StudyPlan",
      "description": "AI generated study plan",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "examDates": { "type": "string" },
        "studyHoursPerDay": { "type": "number" },
        "difficulty": { "type": "string" },
        "planData": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "planData"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/tasks/{taskId}": {
      "schema": "StudyTask",
      "description": "Individual study tasks"
    },
    "/sessions/{sessionId}": {
      "schema": "FocusSession",
      "description": "Focus session logs"
    },
    "/plans/{planId}": {
      "schema": "StudyPlan",
      "description": "Generated study plans"
    }
  }
}
